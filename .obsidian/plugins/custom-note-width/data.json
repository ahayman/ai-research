{
  "language": "auto",
  "defaultWidth": 80,
  "defaultWidthUnit": "%",
  "sliderWidth": 85,
  "yamlKey": "custom-width",
  "enableSlider": true,
  "enableTextInput": true,
  "enablePerNoteWidth": true,
  "unitRanges": {
    "%": {
      "min": 0,
      "max": 100
    },
    "px": {
      "min": 100,
      "max": 4000
    },
    "ch": {
      "min": 10,
      "max": 200
    }
  },
  "enableCodeBlockWidth": false,
  "codeBlockWidth": 800,
  "codeBlockWidthUnit": "px",
  "codeBlockWidthModes": {
    "reading": true,
    "source": true,
    "livePreview": true
  }
}